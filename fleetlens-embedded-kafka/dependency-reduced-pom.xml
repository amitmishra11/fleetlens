<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <artifactId>fleetlens-parent</artifactId>
    <groupId>com.fleetlens</groupId>
    <version>0.1.0-SNAPSHOT</version>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <artifactId>fleetlens-embedded-kafka</artifactId>
  <description>A standalone, plain-Java process that runs a real (in-process) Kafka broker on
        localhost:9092 using Spring Kafka's test support. It replaces a Dockerised
        Kafka + Zookeeper for local development: no containers, no external installs,
        just a JVM listening on the usual Kafka port that any client (including other
        FleetLens processes) can connect to normally.</description>
  <build>
    <finalName>fleetlens-embedded-kafka</finalName>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.fleetlens.embeddedkafka.EmbeddedKafkaMain</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <dependencies>
    <dependency>
      <groupId>org.projectlombok</groupId>
      <artifactId>lombok</artifactId>
      <version>1.18.34</version>
      <scope>provided</scope>
    </dependency>
  </dependencies>
</project>
